# Jupiter API
JUPITER_API_KEY=your_jupiter_api_key
JUPITER_API_URL=https://api.jup.ag

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
PLATFORM_WALLET_PUBKEY=your_platform_wallet_pubkey

# Database (Neon for CF Workers compatibility)
DATABASE_URL=postgresql://user:pass@host/dbname

# Redis (Upstash for CF Workers compatibility)
REDIS_URL=your_upstash_redis_url
REDIS_TOKEN=your_upstash_redis_token

# Firebase Cloud Messaging
FCM_PROJECT_ID=your_firebase_project_id
FCM_PRIVATE_KEY=your_firebase_private_key
FCM_CLIENT_EMAIL=your_firebase_client_email

# Jito
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf

# App
API_URL=http://localhost:8787
WEB_URL=http://localhost:5173
